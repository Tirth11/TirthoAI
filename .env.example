# TirthoAI - Environment Variables
# Only add keys for the models you want to use.
# Models without keys will be automatically hidden from the UI.

# Flask Secret Key
SECRET_KEY=your_secret_key_here

# NVIDIA NIM API Keys
# Get keys from: https://build.nvidia.com/
NVIDIA_API_KEY_NEMOTRON_3=
NVIDIA_API_KEY_PRO=
NVIDIA_API_KEY_GLM51=
NVIDIA_API_KEY_VISION=
NVIDIA_API_KEY_STEP_GEMMA=
NVIDIA_API_KEY_KIMI_K26=
NVIDIA_API_KEY_SARVAM=
NVIDIA_API_KEY_MINIMAX=
NVIDIA_API_KEY_STOCKMARK=

# Shared Key (used by multiple models: DeepSeek R1, Llama 3.3, Gemma 2)
KIMI_26_KEY=
